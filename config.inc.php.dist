<?php

// Default configuration for the Roundcube Catch-all plugin.
// Copy to config.inc.php and adjust as needed.

// Comma-separated list of domains to treat as catch-all, or a single domain.
// Replies to an address on one of these domains auto-create a matching
// identity and preselect it as From.
// $config['catchall_domain'] = '';

// Automatically create identities when replying to an address on the
// configured catch-all domain. When false, users must create identities
// manually in Settings > Identities.
$config['catchall_identity_autocreate'] = true;

// =============================================================================
// Forward Email integration (optional)
// =============================================================================
// When catchall_fe_api_key (or _plain) is set alongside catchall_domain, the
// plugin will auto-create per-alias SMTP credentials via the Forward Email
// API on reply. Leave unset to use shared-credential mode (single alias/SMTP
// password for the whole domain — typically a wildcard alias).

// Forward Email API key (stored encrypted in user preferences via Settings UI).
// $config['catchall_fe_api_key'] = '';

// Plaintext Forward Email API key for administrator/system-level configuration.
// Used as a fallback only when no user-level API key is stored. Suitable for
// single-tenant add-on deployments where the operator provisions the key
// outside the Roundcube UI.
// SECURITY: this key is shared by every user of this Roundcube instance; use a
// domain-scoped Forward Email key rather than an account-wide one.
// $config['catchall_fe_api_key_plain'] = '';

// Automatically delete aliases when identities are removed
$config['catchall_fe_auto_delete'] = false;

// =============================================================================
// Forward Email catch-all password (alternative to per-alias API provisioning)
// =============================================================================
// A domain-wide catch-all password allows SMTP authentication as any address on
// the domain. Generate one at:
//   https://forwardemail.net/my-account/domains/<domain>/advanced-settings#catch-all-passwords
//
// When set, the plugin authenticates SMTP as `<identity-email> + <catch-all-password>`
// for catch-all identities. This is simpler than the per-alias API approach:
// no API key is needed and no aliases are created on Forward Email.
//
// Stored encrypted in user preferences via Settings UI:
// $config['catchall_fe_catchall_password'] = '';
//
// Plaintext fallback for admin/add-on deployments. Used only when no user-level
// value is stored. SECURITY: this password can send as any address on the domain.
// $config['catchall_fe_catchall_password_plain'] = '';
